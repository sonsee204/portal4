# =============================================================================
# Nalee Sports Portal — Environment Template
# =============================================================================
# Copy this file to `.env.local` and fill in real values. `.env*` files
# (except this template) are excluded from git by the .gitignore.
# =============================================================================

# GraphQL API (backend)
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:4000/graphql
# Optional: WebSocket URL for subscriptions. If not set, derived from
# GRAPHQL_URL (http→ws, https→wss).
# NEXT_PUBLIC_GRAPHQL_WS_URL=ws://localhost:4000/graphql

# Middleware JWT verifier (must match backend's JWT_ACCESS_SECRET).
JWT_SECRET=replace-with-strong-secret

# Public site URL (canonical, Open Graph)
NEXT_PUBLIC_SITE_URL=http://localhost:3002

# Public web app URL (tournament live operations)
NEXT_PUBLIC_WEB_URL=http://localhost:3003

# Optional: Google Analytics
NEXT_PUBLIC_GA_ID=

# Debug: hiển thị chi tiết lỗi trên trang error (chỉ dùng tạm khi debug production)
# NEXT_PUBLIC_DEBUG_ERROR_DISPLAY=true

# =============================================================================
# Firebase Phone Auth — FALLBACK ONLY (portal supports password reset)
# =============================================================================
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# App Check (reCAPTCHA v3) site key (distinct from Identity Platform key).
NEXT_PUBLIC_FIREBASE_APP_CHECK_SITE_KEY=
NEXT_PUBLIC_FIREBASE_APP_CHECK_ENABLED=true

# Optional: for GraphQL Codegen (schema path when not in monorepo)
# GRAPHQL_SCHEMA_PATH=../nalee-sports-backend/src/schema.gql
