{
  "name": "nalee-sports-portal",
  "version": "1.6",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3001",
    "prebuild": "npm run codegen",
    "build": "next build",
    "start": "next start --port 3001",
    "lint": "eslint",
    "codegen": "graphql-codegen --config codegen.ts",
    "format": "prettier --write .",
    "icons:sync": "node ../scripts/sync-icons.mjs nalee-sports-portal",
    "schema:sync": "node ../scripts/sync-schema.mjs",
    "schedule-dnd:sync": "node ../scripts/sync-schedule-dnd-lib.mjs",
    "version:sync": "node ../scripts/sync-version.mjs",
    "dev:https": "next dev --experimental-https --experimental-https-key localhost+1-key.pem --experimental-https-cert localhost+1.pem --port 3003"
  },
  "dependencies": {
    "@apollo/client": "^4.1.4",
    "@dnd-kit/react": "^0.3.2",
    "@hookform/resolvers": "^5.2.2",
    "@uiw/react-md-editor": "^4.0.11",
    "clsx": "^2.1.1",
    "firebase": "^12.9.0",
    "framer-motion": "^12.34.0",
    "graphql": "^16.12.0",
    "graphql-tag": "^2.12.6",
    "graphql-ws": "^6.0.7",
    "jose": "^6.1.3",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "papaparse": "^5.5.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.1",
    "react-markdown": "^10.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^6.1.1",
    "@graphql-codegen/typescript": "^5.0.7",
    "@graphql-codegen/typescript-operations": "^5.0.7",
    "@graphql-codegen/typescript-react-apollo": "^4.4.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "ionicons": "^8.0.13",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
