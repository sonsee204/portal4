{
  "name": "nalee-sports-portal",
  "packageManager": "pnpm@10.26.2",
  "version": "1.6",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev --port 3001",
    "prebuild": "pnpm run codegen",
    "build": "next build",
    "start": "next start --port 3001",
    "lint": "eslint",
    "codegen": "graphql-codegen --config codegen.ts",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "size-gate": "node scripts/size-gate.mjs --roots=app,components,hooks,lib --scope=all",
    "size-gate:strict": "node scripts/size-gate.mjs --roots=app,components,hooks,lib --scope=all --strict --warn-baseline",
    "size-gate:warn-baseline:update": "node scripts/size-gate.mjs --roots=app,components,hooks,lib --scope=all --update-warn-baseline",
    "dead-code-gate": "node scripts/dead-code-gate.mjs",
    "dead-code-gate:update": "node scripts/dead-code-gate.mjs --update-baseline",
    "verify:quick": "pnpm run typecheck && pnpm run check:copyright-header && pnpm run lint && pnpm run size-gate:strict && pnpm run dead-code-gate",
    "verify:a-plus": "pnpm run typecheck && pnpm run check:copyright-header && pnpm run lint && pnpm test && pnpm run size-gate:strict && pnpm run dead-code-gate && pnpm run check:shared-sync && pnpm run build",
    "verify:go": "node scripts/check-working-tree-clean.mjs && pnpm run check:schema-drift && pnpm run check:codegen-drift && pnpm run verify:a-plus",
    "check:codegen-drift": "node scripts/check-codegen-drift.mjs",
    "check:schema-drift": "node scripts/check-schema-drift.mjs",
    "check:copyright-header": "node scripts/check-copyright-header.mjs --roots=app,components,hooks,lib,scripts",
    "icons:sync": "node ../scripts/sync-icons.mjs nalee-sports-portal",
    "schema:sync": "node ../scripts/sync-schema.mjs",
    "check:shared-sync": "node scripts/check-shared-sync.mjs",
    "schedule-dnd:sync": "node ../scripts/sync-schedule-dnd-lib.mjs",
    "venue-perms:sync": "node ../scripts/sync-venue-permission-kernel.mjs",
    "promotion-kernel:sync": "node ../scripts/sync-promotion-kernel.mjs",
    "check:promotion-kernel-sync": "node ../scripts/sync-promotion-kernel.mjs --check",
    "print-kernel:sync": "node ../scripts/sync-tournament-print-kernel.mjs",
    "check:print-kernel-sync": "node ../scripts/sync-tournament-print-kernel.mjs --check",
    "sync:shared": "node ../scripts/sync-shared-kernel.mjs --target=nalee-sports-portal",
    "version:sync": "node ../scripts/sync-version.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@apollo/client": "^4.1.4",
    "@dnd-kit/react": "^0.3.2",
    "@hookform/resolvers": "^5.2.2",
    "@uiw/react-md-editor": "^4.0.11",
    "browser-image-compression": "^2.0.2",
    "clsx": "^2.1.1",
    "firebase": "^12.9.0",
    "framer-motion": "^12.34.0",
    "graphql": "^16.12.0",
    "graphql-tag": "^2.12.6",
    "graphql-ws": "^6.0.7",
    "jose": "^6.1.3",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "papaparse": "^5.5.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.1",
    "react-markdown": "^10.1.0",
    "react-to-print": "^3.0.5",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^6.1.1",
    "@graphql-codegen/typescript": "^5.0.7",
    "@graphql-codegen/typescript-operations": "^5.0.7",
    "@graphql-codegen/typescript-react-apollo": "^4.4.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "husky": "^9.1.7",
    "ionicons": "^8.0.13",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.6"
  }
}
